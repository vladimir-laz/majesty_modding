	{"zones"
		{body {proper body sensible} {permit 	body}}
		{Collider "default"}
	}

	{actor}


;#line 9: 	(include "anim.inc")	
;#line 9: entity/units/monsters/boss_werewolf/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{binary "idle_rand01"{speed 0.6}}
		{binary "death"{speed 0.6}}
		{blend "pose_to_blow01"{pose "blow01" begin}}
		{binary "blow01"{speed 0.6}}
		{blend "pose_to_ag_walk"{pose "ag_walk" begin}}
		{binary "ag_walk"{speed 0.6}}
		{blend "pose_to_blow02"{pose "blow02" begin}}
		{binary "blow02"{speed 0.6}}
		{blend "pose_to_idle_rand01"{pose "idle_rand01" begin}}
		{blend "pose_from_death"{pose "death" end}}
	}
}
;#line 9: entity/units/monsters/boss_werewolf/anim.inc END


;#line 10: 	(include "fsm.inc")		
;#line 10: entity/units/monsters/boss_werewolf/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "pose_to_move_default"
	;transations
	{from "from_default"}
	{from "idle_default"}
	{from "pose_to_idle_default"}
}
{StateWork "pose_to_move_default"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_default"
	;transations
	{from "pose_to_move_default"}
	;tags
	{tag "move"}
	{tag "default"}
}
{StateWork "move_default"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.1} }
}

{State "pose_to_idle_default"
	;transations
	{from "move_default"}
	{from "from_default"}
	{from "pose_to_move_default"}
}
{StateWork "pose_to_idle_default"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_default"
	;transations
	{from "pose_to_idle_default"}
	;tags
	{tag "idle"}
	{tag "default"}
}
{StateWork "idle_default"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{random}
	{AnimName "idle" {speed 1} {count 2} }
	{AnimName "idle_rand01" {speed 1} }
}

{State "to_death"
	;transations
	{from "blank01"}
}
{StateWork "to_death"
}

{State "death_anim"
	;transations
	{from "to_death"}
	;tags
	{tag "death_anim"}
}
{StateWork "death_anim"
	{AnimName "death" {speed 1} {frame 11 "WOLFMAN_DEATH_SND"} {frame 49 "DRAGON_DEATH_SND"} {frame 124 "BODYFALL_SND"} }
}

{State "blank01"
	;transations
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_imp_attack02_fight"}
	{from "imp_attack02_fight"}
	{from "from_default"}
	{from "from_fight"}
	{from "death"}
}
{StateWork "blank01"
}

{State "pose_to_attack_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "imp_attack02_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "pose_to_imp_attack02_fight"}
}
{StateWork "pose_to_attack_fight"
	{pose}
	{AnimName "pose_to_blow01" {speed 0.4} }
}

{State "attack_fight"
	;transations
	{from "pose_to_attack_fight"}
	;tags
	{tag "attack"}
	{tag "fight"}
}
{StateWork "attack_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "blow01" {speed 1.1} {frame 15 "DRAGON_SOUND_SND"} {frame 17 "IMP_SWISH_SND"} {frame 32 "IMP_SWISH_SND"} {frame 39 "ATTACK"} {frame 48 "IMP_SWISH_SND"} {frame 63 "IMP_SWISH_SND"} {frame -1 "ATTACK"} }
}

{State "pose_to_move_fight"
	;transations
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "imp_attack02_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "pose_to_imp_attack02_fight"}
}
{StateWork "pose_to_move_fight"
	{pose}
	{AnimName "pose_to_ag_walk" {speed 0.25} }
}

{State "move_fight"
	;transations
	{from "pose_to_move_fight"}
	;tags
	{tag "move"}
	{tag "fight"}
}
{StateWork "move_fight"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_walk" {speed 0.8} }
}

{State "pose_to_idle_fight"
	;transations
	{from "move_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "imp_attack02_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "pose_to_imp_attack02_fight"}
}
{StateWork "pose_to_idle_fight"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_fight"
	;transations
	{from "pose_to_idle_fight"}
	;tags
	{tag "idle"}
	{tag "fight"}
}
{StateWork "idle_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 1} }
}

{State "pose_to_imp_attack01_fight"
	;transations
	{from "attack_fight"}
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "imp_attack02_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack02_fight"}
}
{StateWork "pose_to_imp_attack01_fight"
	{pose}
	{AnimName "pose_to_blow02" {speed 0.4} }
}

{State "imp_attack01_fight"
	;transations
	{from "pose_to_imp_attack01_fight"}
	;tags
	{tag "imp_attack01"}
	{tag "fight"}
}
{StateWork "imp_attack01_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "blow02" {speed 1.1} {frame 17 "WOLFMAN_ATTACK_SND"} {frame 29 "ATTACK"} {frame 38 "WOLFMAN_BITE_SND"} {frame -1 "ATTACK"} }
}

{State "pose_to_imp_attack02_fight"
	;transations
	{from "attack_fight"}
	{from "imp_attack01_fight"}
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_imp_attack02_fight"
	{pose}
	{AnimName "pose_to_idle_rand01" {speed 0.4} }
}

{State "imp_attack02_fight"
	;transations
	{from "pose_to_imp_attack02_fight"}
	;tags
	{tag "imp_attack02"}
	{tag "fight"}
}
{StateWork "imp_attack02_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "idle_rand01" {speed 1.1} {frame 22 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "from_default"
	;transations
	{from "move_default"}
	{from "idle_default"}
	{from "from_fight"}
	{from "death"}
	{from "pose_to_move_default"}
	{from "pose_to_idle_default"}
}
{StateWork "from_default"
	{SyncNotifyStart "MOVE_PAUSE"}
}

{State "from_fight"
	;transations
	{from "from_default"}
	{from "idle_fight"}
	{from "move_fight"}
	{from "attack_fight"}
	{from "imp_attack01_fight"}
	{from "death"}
	{from "imp_attack02_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "pose_to_imp_attack02_fight"}
}
{StateWork "from_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
}

{State "death"
	;transations
	{from "death_anim"}
	;tags
	{tag "death"}
}
{StateWork "death"
	{SyncNotifyStart "FINAL_DEATH"}
	{pose}
	{AnimName "pose_from_death" {speed 0.5} }
}

;********************************************************************
; Subsets
;********************************************************************
{subset "default"
	{enable "default"}
	{disable "fight"}
}

{subset "fight"
	{disable "default"}
	{enable "fight"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

