{entity
	
	{"zones"
		{body {proper body sensible} {permit body}}
	}
	
	{Skeleton
		{animation
			{uv "run"
				{view "hero_Lich_shine"} ;Имя "кости" для которой применяется
					{shiftV 	0 	1 	-0.002} ;Можно определить только U или только V или оба
		 	}
		}
	}
	{actor}
		{"simulator" {able 0} {mass 50}}
	{"Knockback"}
	{"FXAttachment"
		{defaults "undead_lichhead" "fire_pump_big"}
		{defaults "root_transformed" "cheese_trap_fx"}
		{defaults "undead_lichtail1_1" "fire_pump"}
	}



;#line 17: 	(include "anim.inc")		
;#line 17: entity/units/monsters/tormenters/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_to_attack3"{pose "attack3" begin}}
		{binary "attack3"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{blend "pose_to_attack2"{pose "attack2" begin}}
		{binary "attack2"{speed 0.6}}
		{blend "pose_to_attack1"{pose "attack1" begin}}
		{binary "attack1"{speed 0.6}}
		{blend "pose_to_coward_walk"{pose "coward_walk" begin}}
		{binary "coward_walk"{speed 0.6}}
		{binary "death"{speed 0.6}}
		{blend "pose_from_death"{pose "death" end}}
		{blend "pose_from_idle"{pose "idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_massive_fly"{pose "massive_fly" begin}}
		{binary "massive_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
		{binary "idle_rand1"{speed 0.6}}
		{binary "idle_rand2"{speed 0.6}}
	}
}
;#line 17: entity/units/monsters/tormenters/anim.inc END


;#line 18: 	(include "fsm.inc")			
;#line 18: entity/units/monsters/tormenters/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "pose_to_attack_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "imp_attack02_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "pose_to_imp_attack02_fight"}
}
{StateWork "pose_to_attack_fight"
	{pose}
	{AnimName "pose_to_attack3" {speed 0.4} }
}

{State "attack_fight"
	;transations
	{from "pose_to_attack_fight"}
	;tags
	{tag "attack"}
	{tag "fight"}
}
{StateWork "attack_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "attack3" {speed 1.2} {frame 37 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "pose_to_move_fight"
	;transations
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "imp_attack02_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "pose_to_imp_attack02_fight"}
}
{StateWork "pose_to_move_fight"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_fight"
	;transations
	{from "pose_to_move_fight"}
	;tags
	{tag "move"}
	{tag "fight"}
}
{StateWork "move_fight"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.4} }
}

{State "pose_to_idle_fight"
	;transations
	{from "move_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
