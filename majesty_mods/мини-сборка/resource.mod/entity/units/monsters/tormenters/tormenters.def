;********************************************************************
; Subsets
;********************************************************************
{subset "fight"
	{enable "fight"}
	{disable "panic"}
	{disable "default"}
}

{subset "panic"
	{disable "fight"}
	{enable "panic"}
	{disable "default"}
}

{subset "default"
	{disable "fight"}
	{disable "panic"}
	{enable "default"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

