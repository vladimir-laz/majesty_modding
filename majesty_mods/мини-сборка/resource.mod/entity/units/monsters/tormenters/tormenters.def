	;tags
	{tag "idle"}
	{tag "fight"}
}
{StateWork "idle_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 1} }
}

{State "pose_to_imp_attack01_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "attack_fight"}
	{from "from_fight"}
