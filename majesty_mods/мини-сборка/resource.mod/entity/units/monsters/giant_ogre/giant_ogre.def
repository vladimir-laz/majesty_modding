;#line 9: entity/units/monsters/giant_ogre/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_to_death"{pose "death" begin}}
		{binary "death"{speed 0.6}}
		{binary "death_02"{speed 0.6}}
		{blend "pose_to_lazy_idle_stand_up"{pose "lazy_idle_stand_up" begin}}
		{binary "lazy_idle_stand_up"{speed 0.6}}
		{blend "pose_to_lazy_idle"{pose "lazy_idle" begin}}
		{binary "lazy_idle"{speed 0.6}}
		{binary "lazy_idle_rand01"{speed 0.6}}
		{blend "pose_to_lazy_idle_lay_down"{pose "lazy_idle_lay_down" begin}}
		{binary "lazy_idle_lay_down"{speed 0.6}}
		{blend "pose_to_blow"{pose "blow" begin}}
		{binary "blow"{speed 0.6}}
		{binary "blow_02"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_blow_02"{pose "blow_02" begin}}
		{binary "idle_rand_01"{speed 0.6}}
		{binary "idle_rand_02"{speed 0.6}}
		{binary "idle_rand_03"{speed 0.6}}
		{blend "pose_from_idle"{pose "idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
	}
}
;#line 9: entity/units/monsters/giant_ogre/anim.inc END


