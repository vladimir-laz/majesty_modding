{entity
	
	{"zones"
		{body {proper body sensible} {permit 	body}}
		{Collider "default"}
	}
	{Skeleton
		{animation
			{uv "run"
				{view "Undead_Lich2"} ;Имя "кости" для которой применяется
					{shiftV 	0 	1 	-0.002} ;Можно определить только U или только V или оба
		 	}
		}
	}

	{actor}


;#line 18: 	(include "anim.inc")			
;#line 18: entity/units/monsters/boss_lich_double/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_from_idle"{pose "idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_mass_damage_fly"{pose "mass_damage_fly" begin}}
		{binary "mass_damage_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
		{blend "pose_to_death"{pose "death" begin}}
		{binary "death"{speed 0.6}}
		{blend "pose_from_death"{pose "death" end}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{binary "idle_rand01"{speed 0.6}}
		{binary "idle_rand02"{speed 0.6}}
		{blend "pose_to_magic_attack01"{pose "magic_attack01" begin}}
		{binary "magic_attack01"{speed 0.6}}
		{blend "pose_to_magic_attack02"{pose "magic_attack02" begin}}
		{binary "magic_attack02"{speed 0.6}}
	}
}
;#line 18: entity/units/monsters/boss_lich_double/anim.inc END


