{entity
	
	{"zones"
		{body {proper body sensible} {permit body}}
		{Collider "default"}
	}	
	
	{actor}


;#line 10: 	(include "anim.inc")			
;#line 10: entity/units/monsters/boss_skeleton_king/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_from_idle"{pose "idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_blow01"{pose "blow01" begin}}
		{binary "blow01"{speed 0.6}}
		{binary "blow02"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{binary "idle_rand01"{speed 0.6}}
		{blend "pose_to_death"{pose "death" begin}}
		{binary "death"{speed 0.6}}
	}
}
;#line 10: entity/units/monsters/boss_skeleton_king/anim.inc END


;#line 11: 	(include "fsm.inc")		
;#line 11: entity/units/monsters/boss_skeleton_king/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "freeze"
	;transations
	{from "stun"}
	{from "pose_to_stun"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
	;tags
	{tag "freeze"}
}
{StateWork "freeze"
	{pose}
	{AnimName "pose_from_idle" {speed 0.1} }
}

{State "pose_to_stun"
	;transations
	{from "freeze"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "pose_to_stun"
	{pose}
	{AnimName "pose_to_stun" {speed 0.1} }
}

{State "stun"
	;transations
	{from "pose_to_stun"}
	;tags
	{tag "stun"}
}
{StateWork "stun"
	{looped}
	{AnimName "stun" {speed 1} }
}

{State "from_unmoved_1"
	;transations
	{from "stun"}
	{from "freeze"}
	{from "pose_to_stun"}
}
{StateWork "from_unmoved_1"
}

{State "from_unmoved_2"
	;transations
	{from "from_unmoved_1"}
}
{StateWork "from_unmoved_2"
}

{State "pose_to_attack_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "pose_to_attack_fight"
	{pose}
	{AnimName "pose_to_blow01" {speed 0.4} }
}

{State "attack_fight"
	;transations
	{from "pose_to_attack_fight"}
	;tags
	{tag "attack"}
	{tag "fight"}
}
{StateWork "attack_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{random}
	{AnimName "blow01" {speed 1} {frame 2 "SKELETON_BIG_SND"} {frame 30 "ATTACK"} {frame -1 "ATTACK"} }
	{AnimName "blow02" {speed 1} {frame 2 "SKELETON_BIG_SND"} {frame 26 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "pose_to_move_fight"
	;transations
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "pose_to_move_fight"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_fight"
	;transations
	{from "pose_to_move_fight"}
	;tags
	{tag "move"}
	{tag "fight"}
}
{StateWork "move_fight"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.3} }
}

{State "pose_to_idle_fight"
	;transations
	{from "move_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
}
{StateWork "pose_to_idle_fight"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_fight"
	;transations
	{from "pose_to_idle_fight"}
	;tags
	{tag "idle"}
	{tag "fight"}
}
{StateWork "idle_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 1} }
}

{State "pose_to_move_default"
	;transations
	{from "from_default"}
	{from "idle_default"}
	{from "pose_to_idle_default"}
}
{StateWork "pose_to_move_default"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_default"
	;transations
	{from "pose_to_move_default"}
	;tags
	{tag "move"}
	{tag "default"}
}
{StateWork "move_default"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1} }
}

{State "pose_to_idle_default"
	;transations
	{from "move_default"}
	{from "from_default"}
	{from "pose_to_move_default"}
}
{StateWork "pose_to_idle_default"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_default"
	;transations
	{from "pose_to_idle_default"}
	;tags
	{tag "idle"}
	{tag "default"}
}
{StateWork "idle_default"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{random}
	{AnimName "idle" {speed 1} {count 2} }
	{AnimName "idle_rand01" {speed 1} }
}

{State "pose_to_idle_panic"
	;transations
	{from "from_panic"}
	{from "move_panic"}
	{from "pose_to_move_panic"}
}
{StateWork "pose_to_idle_panic"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_panic"
	;transations
	{from "pose_to_idle_panic"}
	;tags
	{tag "idle"}
	{tag "panic"}
}
{StateWork "idle_panic"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 0.9} }
}

{State "pose_to_move_panic"
	;transations
	{from "from_panic"}
	{from "idle_panic"}
	{from "pose_to_idle_panic"}
}
{StateWork "pose_to_move_panic"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_panic"
	;transations
	{from "pose_to_move_panic"}
	;tags
	{tag "move"}
	{tag "panic"}
}
{StateWork "move_panic"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.3} }
}

{State "to_death"
	;transations
	{from "blank01"}
}
{StateWork "to_death"
	{SyncNotifyStart "DEATH"}
	{pose}
	{AnimName "pose_to_death" {speed 0.25} }
}

{State "death"
	;transations
	{from "to_death"}
	;tags
	{tag "death"}
}
{StateWork "death"
	{SyncNotifyFinish "DEATH"}
	{AnimName "death" {speed 1} {frame 52 "BODYFALL_BONES_PLATE2_SND"} {frame -1 "DEATH"} }
}

{State "blank01"
	;transations
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "blank01"
}

{State "from_default"
	;transations
	{from "move_default"}
	{from "idle_default"}
	{from "from_panic"}
	{from "from_fight"}
	{from "death"}
	{from "from_unmoved_2"}
	{from "pose_to_move_default"}
	{from "pose_to_idle_default"}
}
{StateWork "from_default"
	{SyncNotifyStart "MOVE_PAUSE"}
}

{State "from_panic"
	;transations
	{from "idle_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_fight"}
	{from "death"}
	{from "from_unmoved_2"}
	{from "pose_to_idle_panic"}
	{from "pose_to_move_panic"}
}
{StateWork "from_panic"
	{SyncNotifyStart "MOVE_PAUSE"}
}

{State "from_fight"
	;transations
	{from "from_default"}
	{from "from_panic"}
	{from "idle_fight"}
	{from "attack_fight"}
	{from "move_fight"}
	{from "death"}
	{from "from_unmoved_2"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "from_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
}

;********************************************************************
; Subsets
;********************************************************************
{subset "fight"
	{enable "fight"}
	{disable "default"}
	{disable "panic"}
}

{subset "default"
	{disable "fight"}
	{enable "default"}
	{disable "panic"}
}

{subset "panic"
	{disable "fight"}
	{disable "default"}
	{enable "panic"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

