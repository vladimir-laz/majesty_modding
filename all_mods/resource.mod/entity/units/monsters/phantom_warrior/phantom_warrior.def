{entity
	
	{"zones"
		{body {proper body sensible} {permit body}}
	}
	{actor}
	{xform scale 1.2}


;#line 9: 	(include "anim.inc")		
;#line 9: entity/units/monsters/phantom_warrior/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_from_ag_idle"{pose "ag_idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_mass_damage_fly"{pose "mass_damage_fly" begin}}
		{binary "mass_damage_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
		{blend "pose_to_death_2"{pose "death_2" begin}}
		{binary "death_2"{speed 0.6}}
		{blend "pose_from_death_2"{pose "death_2" end}}
		{blend "pose_to_ag_walk"{pose "ag_walk" begin}}
		{binary "ag_walk"{speed 0.6}}
		{blend "pose_to_ag_idle"{pose "ag_idle" begin}}
		{binary "ag_idle"{speed 0.6}}
		{blend "pose_to_blow_1"{pose "blow_1" begin}}
		{binary "blow_1"{speed 0.6}}
		{binary "blow_2"{speed 0.6}}
		{blend "pose_to_blow_3"{pose "blow_3" begin}}
		{binary "blow_3"{speed 0.6}}
		{blend "pose_to_blow_special"{pose "blow_special" begin}}
		{binary "blow_special"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{binary "idle_rand_1"{speed 0.6}}
		{binary "idle_rand_2"{speed 0.6}}
		{binary "idle_rand_3"{speed 0.6}}
		{blend "pose_to_coward_walk"{pose "coward_walk" begin}}
		{binary "coward_walk"{speed 0.6}}
		{blend "pose_to_lazy_idle"{pose "lazy_idle" begin}}
		{binary "lazy_idle"{speed 0.6}}
	}
}
;#line 9: entity/units/monsters/phantom_warrior/anim.inc END


