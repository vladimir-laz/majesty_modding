;********************************************************************
; Subsets
;********************************************************************
{subset "fight"
	{enable "fight"}
	{disable "default"}
	{disable "panic"}
	{disable "laziness"}
}

{subset "default"
	{disable "fight"}
	{enable "default"}
	{disable "panic"}
	{disable "laziness"}
}

{subset "panic"
	{disable "fight"}
	{disable "default"}
	{enable "panic"}
	{disable "laziness"}
}

{subset "laziness"
	{disable "fight"}
	{disable "default"}
	{disable "panic"}
	{enable "laziness"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

