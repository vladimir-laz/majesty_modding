;********************************************************************
; Subsets
;********************************************************************
{subset "panic"
	{enable "panic"}
	{disable "default"}
	{disable "fight"}
}

{subset "default"
	{disable "panic"}
	{enable "default"}
	{disable "fight"}
}

{subset "fight"
	{disable "panic"}
	{disable "default"}
	{enable "fight"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

