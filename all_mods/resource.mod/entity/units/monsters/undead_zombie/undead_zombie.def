{entity
	
	{"zones"
		{body {proper body sensible} {permit body}}
		{Collider "default"}
	}
	
	{"FXAttachment"
		{defaults "root_transformed" "undead_zombie_fly"}
	}
	{actor}


;#line 13: 	(include "anim.inc")			
;#line 13: entity/units/monsters/undead_zombie/anim.inc BEGIN
{Skeleton
	{animation
		{binary "death"{speed 0.6}}
		{blend "pose_from_death"{pose "death" end}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{blend "pose_to_ag_walk"{pose "ag_walk" begin}}
		{binary "ag_walk"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_blow01"{pose "blow01" begin}}
		{binary "blow01"{speed 0.6}}
		{binary "blow02"{speed 0.6}}
		{blend "pose_to_magic_attack"{pose "magic_attack" begin}}
		{binary "magic_attack"{speed 0.6}}
		{blend "pose_from_idle"{pose "idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_mass_damage_fly"{pose "mass_damage_fly" begin}}
		{binary "mass_damage_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
	}
}
;#line 13: entity/units/monsters/undead_zombie/anim.inc END


;#line 14: 	(include "fsm.inc")		
;#line 14: entity/units/monsters/undead_zombie/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "to_death"
	;transations
	{from "blank01"}
}
{StateWork "to_death"
}

{State "death_anim"
	;transations
	{from "to_death"}
	;tags
	{tag "death_anim"}
}
{StateWork "death_anim"
	{AnimName "death" {speed 1} {frame 10 "ZOMBIE_DEATH_SND"} {frame 73 "BODYFALL_SND"} }
}

{State "blank01"
	;transations
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "imp_attack01_fight"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "blank01"
}

{State "death"
	;transations
	{from "death_anim"}
	{from "from_unmoved_5"}
	;tags
	{tag "death"}
}
{StateWork "death"
	{SyncNotifyStart "FINAL_DEATH"}
	{pose}
	{AnimName "pose_from_death" {speed 0.5} }
}

{State "pose_to_idle_panic"
	;transations
	{from "from_panic"}
	{from "move_panic"}
	{from "pose_to_move_panic"}
}
{StateWork "pose_to_idle_panic"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_panic"
	;transations
	{from "pose_to_idle_panic"}
	;tags
	{tag "idle"}
	{tag "panic"}
}
{StateWork "idle_panic"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 0.9} }
}

{State "pose_to_move_panic"
	;transations
	{from "from_panic"}
	{from "idle_panic"}
	{from "pose_to_idle_panic"}
}
{StateWork "pose_to_move_panic"
	{pose}
	{AnimName "pose_to_ag_walk" {speed 0.25} }
}

{State "move_panic"
	;transations
	{from "pose_to_move_panic"}
	;tags
	{tag "move"}
	{tag "panic"}
}
{StateWork "move_panic"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_walk" {speed 1.2} }
}

{State "pose_to_move_default"
	;transations
	{from "from_default"}
	{from "idle_default"}
	{from "pose_to_idle_default"}
}
{StateWork "pose_to_move_default"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_default"
	;transations
	{from "pose_to_move_default"}
	;tags
	{tag "move"}
	{tag "default"}
}
{StateWork "move_default"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 0.9} }
}

{State "pose_to_idle_default"
	;transations
	{from "move_default"}
	{from "from_default"}
	{from "pose_to_move_default"}
}
{StateWork "pose_to_idle_default"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_default"
	;transations
	{from "pose_to_idle_default"}
	;tags
	{tag "idle"}
	{tag "default"}
}
{StateWork "idle_default"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 1} }
}

{State "pose_to_attack_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_attack_fight"
	{pose}
	{AnimName "pose_to_blow01" {speed 0.4} }
}

{State "attack_fight"
	;transations
	{from "pose_to_attack_fight"}
	;tags
	{tag "attack"}
	{tag "fight"}
}
{StateWork "attack_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{random}
	{AnimName "blow01" {speed 1.6} {frame 36 "ZOMBIE_BLOW_SND"} {frame 43 "ATTACK"} {frame -1 "ATTACK"} }
	{AnimName "blow02" {speed 1.6} {frame 50 "ZOMBIE_BLOW_SND"} {frame 72 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "pose_to_move_fight"
	;transations
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_move_fight"
	{pose}
	{AnimName "pose_to_ag_walk" {speed 0.25} }
}

{State "move_fight"
	;transations
	{from "pose_to_move_fight"}
	;tags
	{tag "move"}
	{tag "fight"}
}
{StateWork "move_fight"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_walk" {speed 1} }
}

{State "pose_to_idle_fight"
	;transations
	{from "move_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_idle_fight"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_fight"
	;transations
	{from "pose_to_idle_fight"}
	;tags
	{tag "idle"}
	{tag "fight"}
}
{StateWork "idle_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 1} }
}

{State "pose_to_imp_attack01_fight"
	;transations
	{from "attack_fight"}
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "pose_to_imp_attack01_fight"
	{pose}
	{AnimName "pose_to_magic_attack" {speed 0.4} }
}

{State "imp_attack01_fight"
	;transations
	{from "pose_to_imp_attack01_fight"}
	;tags
	{tag "imp_attack01"}
	{tag "fight"}
}
{StateWork "imp_attack01_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "magic_attack" {speed 1} {frame 50 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "freeze"
	;transations
	{from "stun"}
	{from "pose_to_stun"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_attack_fight"}
