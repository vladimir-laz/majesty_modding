;********************************************************************
; Subsets
;********************************************************************
{subset "default"
	{enable "default"}
	{disable "panic"}
	{disable "fight"}
}

{subset "panic"
	{disable "default"}
	{enable "panic"}
	{disable "fight"}
}

{subset "fight"
	{disable "default"}
	{disable "panic"}
	{enable "fight"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

