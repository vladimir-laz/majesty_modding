{entity
	
	{"zones"
		{body {proper body sensible} {permit 	body}}
		{Collider "default"}
	}

	{actor}


;#line 10: 	(include "anim.inc")	
;#line 10: entity/units/monsters/fantasy_minotaur/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{binary "idle_rand_01"{speed 0.6}}
		{binary "idle_rand_02"{speed 0.6}}
		{blend "pose_to_ag_walk"{pose "ag_walk" begin}}
		{binary "ag_walk"{speed 0.6}}
		{binary "death"{speed 0.6}}
		{blend "pose_from_death"{pose "death" end}}
		{blend "pose_to_blow"{pose "blow" begin}}
		{binary "blow"{speed 0.6}}
		{binary "blow_02"{speed 0.6}}
		{blend "pose_from_idle"{pose "idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_mass_damage_fly"{pose "mass_damage_fly" begin}}
		{binary "mass_damage_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
	}
}
;#line 10: entity/units/monsters/fantasy_minotaur/anim.inc END


;#line 11: 	(include "fsm.inc")		
;#line 11: entity/units/monsters/fantasy_minotaur/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "pose_to_move_default"
	;transations
	{from "from_default"}
	{from "idle_default"}
	{from "pose_to_idle_default"}
}
{StateWork "pose_to_move_default"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_default"
	;transations
	{from "pose_to_move_default"}
	;tags
	{tag "move"}
	{tag "default"}
}
{StateWork "move_default"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.3} }
}

{State "pose_to_idle_default"
	;transations
	{from "move_default"}
	{from "from_default"}
	{from "pose_to_move_default"}
}
{StateWork "pose_to_idle_default"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_default"
	;transations
	{from "pose_to_idle_default"}
	;tags
	{tag "idle"}
	{tag "default"}
}
{StateWork "idle_default"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{random}
	{AnimName "idle" {speed 1} {count 5} }
	{AnimName "idle_rand_01" {speed 1} }
	{AnimName "idle_rand_02" {speed 1} }
}

{State "pose_to_idle_panic"
	;transations
	{from "from_panic"}
	{from "move_panic"}
	{from "pose_to_move_panic"}
}
{StateWork "pose_to_idle_panic"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_panic"
	;transations
	{from "pose_to_idle_panic"}
	;tags
	{tag "idle"}
	{tag "panic"}
}
{StateWork "idle_panic"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 0.8} }
}

{State "pose_to_move_panic"
	;transations
	{from "from_panic"}
	{from "idle_panic"}
	{from "pose_to_idle_panic"}
}
{StateWork "pose_to_move_panic"
	{pose}
	{AnimName "pose_to_ag_walk" {speed 0.25} }
}

{State "move_panic"
	;transations
	{from "pose_to_move_panic"}
	;tags
	{tag "move"}
	{tag "panic"}
}
{StateWork "move_panic"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_walk" {speed 1.1} }
}

{State "to_death"
	;transations
	{from "blank01"}
}
{StateWork "to_death"
}

{State "death_anim"
	;transations
	{from "to_death"}
	;tags
	{tag "death_anim"}
}
{StateWork "death_anim"
	{AnimName "death" {speed 1} {frame 17 "MINOTAUR_PREDEATH_SND"} {frame 100 "MINOTAUR_DEATH_SND"} {frame 154 "BODYFALL_SND"} }
}

{State "blank01"
	;transations
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "blank01"
}

{State "death"
	;transations
	{from "death_anim"}
	{from "from_unmoved_5"}
	;tags
	{tag "death"}
}
{StateWork "death"
	{SyncNotifyStart "FINAL_DEATH"}
	{pose}
	{AnimName "pose_from_death" {speed 0.5} }
}

{State "pose_to_attack_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "pose_to_attack_fight"
	{pose}
	{AnimName "pose_to_blow" {speed 0.4} }
}

{State "attack_fight"
	;transations
	{from "pose_to_attack_fight"}
	;tags
	{tag "attack"}
	{tag "fight"}
}
{StateWork "attack_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{random}
	{AnimName "blow" {speed 1.4} {frame 33 "MINOTAUR_SMALL_BLOW_SND"} {frame 36 "WHOOSH_FAST_LOW_SND"} {frame 45 "ATTACK"} {frame -1 "ATTACK"} }
	{AnimName "blow_02" {speed 1.4} {frame 48 "MINOTAUR_SMALL_BLOW_SND"} {frame 56 "WHOOSH_FAST_LOW_SND"} {frame 61 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "pose_to_move_fight"
	;transations
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "pose_to_move_fight"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_fight"
	;transations
	{from "pose_to_move_fight"}
	;tags
	{tag "move"}
	{tag "fight"}
}
{StateWork "move_fight"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.3} }
}

{State "pose_to_idle_fight"
	;transations
	{from "move_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
}
{StateWork "pose_to_idle_fight"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_fight"
	;transations
	{from "pose_to_idle_fight"}
	;tags
	{tag "idle"}
	{tag "fight"}
}
{StateWork "idle_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 1} }
}

{State "freeze"
	;transations
	{from "stun"}
	{from "pose_to_stun"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
	;tags
	{tag "freeze"}
}
{StateWork "freeze"
	{pose}
	{AnimName "pose_from_idle" {speed 0.1} }
}

{State "pose_to_stun"
	;transations
	{from "freeze"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "pose_to_stun"
	{pose}
	{AnimName "pose_to_stun" {speed 0.1} }
}

{State "stun"
	;transations
	{from "pose_to_stun"}
	;tags
	{tag "stun"}
}
{StateWork "stun"
	{looped}
	{AnimName "stun" {speed 1} }
}

{State "from_unmoved_1"
	;transations
	{from "freeze"}
	{from "stun"}
	{from "stand_up"}
	{from "pose_to_stun"}
}
{StateWork "from_unmoved_1"
}

{State "from_unmoved_2"
	;transations
	{from "from_unmoved_1"}
}
{StateWork "from_unmoved_2"
}

{State "pose_to_mass_damage"
	;transations
	{from "from_stun_1"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
