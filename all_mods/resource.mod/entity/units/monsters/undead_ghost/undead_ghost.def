{entity
	
	{"zones"
		{Collider "default"}
		{body {proper body sensible} {permit body}}
	}
	{Skeleton
		{animation
			{uv "run"
				{view "ghost_skin"} ;Имя "кости" для которой применяется
					{shiftV 	0 	1 	-0.002} ;Можно определить только U или только V или оба
		 	}
		}
	}
	{"FXAttachment"
		{defaults "undead_ghost_fx_head" "undead_ghost_light_small"}
		{delay 0.5} {delay_min 0.0}
		{defaults "undead_ghost_fx_body" "undead_ghost_light"}
		{delay 0.5} {delay_min 0.0}
	}
	{flags "no_group_mesh"}
	{actor}
	{xform scale 1.3}


;#line 25: 	(include "anim.inc")		
;#line 25: entity/units/monsters/undead_ghost/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_from_ag_idle"{pose "ag_idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_mass_damage_fly"{pose "mass_damage_fly" begin}}
		{binary "mass_damage_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
		{blend "pose_to_blow"{pose "blow" begin}}
		{binary "blow"{speed 0.6}}
		{blend "pose_to_ag_walk"{pose "ag_walk" begin}}
		{binary "ag_walk"{speed 0.6}}
		{blend "pose_to_ag_idle"{pose "ag_idle" begin}}
		{binary "ag_idle"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{binary "idle_rand"{speed 0.6}}
		{binary "death"{speed 0.6}}
		{blend "pose_from_death"{pose "death" end}}
	}
}
;#line 25: entity/units/monsters/undead_ghost/anim.inc END


;#line 26: 	(include "fsm.inc")			
;#line 26: entity/units/monsters/undead_ghost/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "freeze"
	;transations
	{from "stun"}
	{from "pose_to_stun"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
	;tags
	{tag "freeze"}
}
{StateWork "freeze"
	{pose}
	{AnimName "pose_from_ag_idle" {speed 0.1} }
}

{State "pose_to_stun"
	;transations
	{from "freeze"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "pose_to_stun"
	{pose}
	{AnimName "pose_to_stun" {speed 0.1} }
}

{State "stun"
	;transations
	{from "pose_to_stun"}
	;tags
	{tag "stun"}
}
{StateWork "stun"
	{looped}
	{AnimName "stun" {speed 1} }
}

{State "from_unmoved_1"
	;transations
	{from "freeze"}
	{from "stun"}
	{from "stand_up"}
	{from "pose_to_stun"}
}
{StateWork "from_unmoved_1"
}

{State "from_unmoved_2"
	;transations
	{from "from_unmoved_1"}
}
{StateWork "from_unmoved_2"
}

{State "pose_to_mass_damage"
	;transations
	{from "from_stun_1"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "pose_to_mass_damage"
	{pose}
	{AnimName "pose_to_mass_damage_fly" {speed 0.001} }
}

{State "mass_damage"
	;transations
	{from "pose_to_mass_damage"}
	;tags
	{tag "mass_damage"}
}
{StateWork "mass_damage"
	{SyncNotifyStart "MASS_FLY"}
	{looped}
	{AnimName "mass_damage_fly" {speed 1} }
}

{State "stand_up"
	;transations
	{from "mass_damage"}
	{from "pose_to_mass_damage"}
	;tags
	{tag "stand_up"}
}
{StateWork "stand_up"
	{SyncNotifyFinish "STAND_READY"}
	{AnimName "massive_stand_up" {speed 1.1} }
}

{State "from_unmoved_3"
	;transations
	{from "mass_damage"}
	{from "pose_to_mass_damage"}
}
{StateWork "from_unmoved_3"
}

{State "from_unmoved_4"
	;transations
	{from "from_unmoved_3"}
}
{StateWork "from_unmoved_4"
}

{State "from_unmoved_5"
	;transations
	{from "from_unmoved_4"}
}
{StateWork "from_unmoved_5"
}

{State "from_stun_2"
	;transations
	{from "from_stun_3"}
}
{StateWork "from_stun_2"
}

{State "from_stun_3"
	;transations
	{from "freeze"}
	{from "stun"}
	{from "pose_to_stun"}
}
{StateWork "from_stun_3"
}

{State "from_stun_1"
	;transations
	{from "from_stun_2"}
}
{StateWork "from_stun_1"
}

{State "pose_to_attack_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "pose_to_attack_fight"
	{pose}
	{AnimName "pose_to_blow" {speed 0.4} }
}

{State "attack_fight"
	;transations
	{from "pose_to_attack_fight"}
	;tags
	{tag "attack"}
	{tag "fight"}
}
{StateWork "attack_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "blow" {speed 1.2} {frame 1 "GHOST_BLOW_SND"} {frame 32 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "pose_to_move_fight"
	;transations
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "pose_to_move_fight"
	{pose}
	{AnimName "pose_to_ag_walk" {speed 0.25} }
}

{State "move_fight"
	;transations
	{from "pose_to_move_fight"}
	;tags
	{tag "move"}
	{tag "fight"}
}
{StateWork "move_fight"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_walk" {speed 1.2} }
}

{State "pose_to_idle_fight"
	;transations
	{from "move_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
}
{StateWork "pose_to_idle_fight"
	{pose}
	{AnimName "pose_to_ag_idle" {speed 0.25} }
}

{State "idle_fight"
	;transations
	{from "pose_to_idle_fight"}
	;tags
	{tag "idle"}
	{tag "fight"}
}
{StateWork "idle_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_idle" {speed 1} }
}

{State "pose_to_move_default"
	;transations
	{from "from_default"}
	{from "idle_default"}
	{from "pose_to_idle_default"}
}
{StateWork "pose_to_move_default"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_default"
	;transations
	{from "pose_to_move_default"}
	;tags
	{tag "move"}
	{tag "default"}
}
{StateWork "move_default"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.1} }
}

{State "pose_to_idle_default"
	;transations
	{from "move_default"}
	{from "from_default"}
	{from "pose_to_move_default"}
}
{StateWork "pose_to_idle_default"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_default"
	;transations
	{from "pose_to_idle_default"}
	;tags
	{tag "idle"}
	{tag "default"}
}
{StateWork "idle_default"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{random}
	{AnimName "idle" {speed 1} {count 4} }
	{AnimName "idle_rand" {speed 1} }
}

{State "pose_to_idle_panic"
	;transations
	{from "from_panic"}
	{from "move_panic"}
	{from "pose_to_move_panic"}
}
{StateWork "pose_to_idle_panic"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_panic"
	;transations
	{from "pose_to_idle_panic"}
	;tags
	{tag "idle"}
	{tag "panic"}
}
{StateWork "idle_panic"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 0.9} }
}

{State "pose_to_move_panic"
	;transations
	{from "from_panic"}
	{from "idle_panic"}
	{from "pose_to_idle_panic"}
}
{StateWork "pose_to_move_panic"
	{pose}
	{AnimName "pose_to_ag_walk" {speed 0.25} }
}

{State "move_panic"
	;transations
	{from "pose_to_move_panic"}
	;tags
	{tag "move"}
	{tag "panic"}
}
{StateWork "move_panic"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_walk" {speed 1.2} }
}

{State "to_death"
	;transations
	{from "blank01"}
}
{StateWork "to_death"
}

{State "death_anim"
	;transations
	{from "to_death"}
	;tags
	{tag "death_anim"}
}
{StateWork "death_anim"
	{AnimName "death" {speed 1} {frame 1 "GHOST_DEATH_SND"} }
}

{State "blank01"
	;transations
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "blank01"
}

{State "death"
	;transations
	{from "death_anim"}
	{from "from_unmoved_5"}
	;tags
	{tag "death"}
}
{StateWork "death"
	{SyncNotifyStart "FINAL_DEATH"}
	{pose}
	{AnimName "pose_from_death" {speed 0.5} }
}

{State "from_default"
	;transations
	{from "move_default"}
	{from "idle_default"}
	{from "from_panic"}
	{from "from_fight"}
	{from "death"}
	{from "from_unmoved_2"}
	{from "pose_to_move_default"}
	{from "pose_to_idle_default"}
}
{StateWork "from_default"
	{SyncNotifyStart "MOVE_PAUSE"}
}

{State "from_panic"
	;transations
	{from "idle_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_fight"}
	{from "death"}
	{from "from_unmoved_2"}
	{from "pose_to_idle_panic"}
	{from "pose_to_move_panic"}
}
{StateWork "from_panic"
	{SyncNotifyStart "MOVE_PAUSE"}
}

{State "from_fight"
	;transations
	{from "from_default"}
	{from "from_panic"}
	{from "idle_fight"}
	{from "move_fight"}
	{from "attack_fight"}
	{from "death"}
	{from "from_unmoved_2"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "from_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
}

;********************************************************************
; Subsets
;********************************************************************
{subset "fight"
	{enable "fight"}
	{disable "default"}
	{disable "panic"}
}

{subset "default"
	{disable "fight"}
	{enable "default"}
	{disable "panic"}
}

{subset "panic"
	{disable "fight"}
	{disable "default"}
	{enable "panic"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

