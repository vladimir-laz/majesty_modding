{"visialstatemanager"
	{desc
		{enable "ENTERING_HERO"} 
		{ref "object43_l2__vol_0"} {name "oneEnteringSnd"} {effect}
	}

	{desc
		{enable "EXITING_HERO"}
		{ref "object43_l2__vol_0"} {name "oneExitingSnd"} {effect}
	}		
	
	{desc ; анимаци€ молотилки
		{enable "PEOPLE_INSIDE"} 
		{ref "object49_l2_dust_smithy"} {name "people_inside"} {anim} {looped}
	}
	{desc ; анимаци€ молотилки
		{enable "PEOPLE_INSIDE"} 
		{ref "object50_l2_dust_smithy"} {name "people_inside"} {anim} {looped}
	}
	{desc ;озвучка молотилок
		{enable "PEOPLE_INSIDE"} 
		{ref "p_sound_forcer1"} {name "smithy_forcer_fx"} {effect} {detachoff} {looped} {single}
	}
	{desc ;озвучка молотилок
		{enable "PEOPLE_INSIDE"} 
		{ref "p_sound_forcer2"} {name "smithy_forcer_fx"} {effect} {detachoff} {looped} {single}
	}
	{desc ;анимаци€ вращени€ колеса, люди внутри
		{enable "PEOPLE_INSIDE"} 
		{ref "object44_l2_base_smithy"} {name "people_inside"} {anim} {looped}
	}
	{desc ;анимаци€ вращени€ колеса, айдл и нет людей внутри
		{enable "IDLE" "BUILDING" "BROKING"}
		{disable "PEOPLE_INSIDE"}
		{ref "object44_l2_base_smithy"} {name "idle"} {anim} {looped}
	}
	{desc ;озвучка вращени€ колеса, p_sound_gearwheel, эффектом smithy_gearwheel_fx
		{enable "IDLE" "BUILDING" "BROKING" "PEOPLE_INSIDE"} 
		{ref "p_sound_gearwheel"} {name "smithy_gearwheel_fx"} {effect} {looped} {detachoff} {single}
	}

	{desc
		{enable "PEOPLE_INSIDE"} 
		{ref "p_fx_1u_smoke"} {name "smoke_radial_start"} {single} {effect} {detachoff} {looped}
	}
	{desc
		{enable "PEOPLE_INSIDE"} 
		{ref "p_fx_2u_smoke"} {name "smoke_radial_start"} {single} {effect} {detachoff} {looped}
	}
	{desc
		{enable "PEOPLE_INSIDE"} 
		{ref "p_fx_3u_smoke"} {name "smoke_radial_start"} {single} {effect} {detachoff} {looped}
	}

	{desc ;включаем обычна€ текстура
		{enable "NO_PEOPLE_INSIDE"} 
		{name ""} {texmode_whole}
	}
	{desc ;включаем текстура со светом в окошках
		{enable "PEOPLE_INSIDE"} 
		{name "01"} {texmode_whole}
	}
	{desc ;fx effect for 3rd level smithy
		{enable "IDLE" "BUILDING" "BROKING" "PEOPLE_INSIDE"} 
		{ref "smithy_point_fx_l3"} {name "smithy_fx_l3"} {effect} {looped} {detachoff} {single}
	}
}

