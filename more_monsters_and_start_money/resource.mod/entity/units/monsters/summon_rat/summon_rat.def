{entity
	
	{"zones"
		{Collider "default"}
		{body {proper body sensible} {permit 	body}}
	}
	{"ItemsAttachment"
		{defaults "summon_point" "summon_runes"}
	}
	{actor}

;#line 11: 	(include "anim.inc")			
;#line 11: entity/units/monsters/summon_rat/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_from_ag_idle"{pose "ag_idle" end}}
		{blend "pose_to_ag_idle"{pose "ag_idle" begin}}
		{binary "ag_idle"{speed 0.6}}
		{blend "pose_to_mass_damage_fly"{pose "mass_damage_fly" begin}}
		{binary "mass_damage_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
		{binary "death"{speed 0.6}}
		{blend "pose_from_death"{pose "death" end}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_blow"{pose "blow" begin}}
		{binary "blow"{speed 0.6}}
	}
}
;#line 11: entity/units/monsters/summon_rat/anim.inc END


;#line 12: 	(include "fsm.inc")		
;#line 12: entity/units/monsters/summon_rat/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "freeze"
	;transations
	{from "stun"}
	{from "pose_to_stun"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
	;tags
	{tag "freeze"}
}
{StateWork "freeze"
	{pose}
	{AnimName "pose_from_ag_idle" {speed 0.1} }
}

{State "pose_to_stun"
	;transations
	{from "freeze"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "pose_to_stun"
	{pose}
	{AnimName "pose_to_ag_idle" {speed 0.1} }
}

{State "stun"
	;transations
	{from "pose_to_stun"}
	;tags
	{tag "stun"}
}
{StateWork "stun"
	{looped}
	{AnimName "ag_idle" {speed 1} }
}

{State "from_unmoved_1"
	;transations
	{from "freeze"}
	{from "stun"}
	{from "stand_up"}
	{from "pose_to_stun"}
}
{StateWork "from_unmoved_1"
}

{State "from_unmoved_2"
	;transations
	{from "from_unmoved_1"}
}
{StateWork "from_unmoved_2"
}

{State "pose_to_mass_damage"
	;transations
	{from "from_stun_1"}
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "pose_to_mass_damage"
	{pose}
	{AnimName "pose_to_mass_damage_fly" {speed 0.001} }
}

{State "mass_damage"
	;transations
	{from "pose_to_mass_damage"}
	;tags
	{tag "mass_damage"}
}
{StateWork "mass_damage"
	{SyncNotifyStart "MASS_FLY"}
	{looped}
	{AnimName "mass_damage_fly" {speed 1} }
}

{State "stand_up"
	;transations
	{from "mass_damage"}
	{from "pose_to_mass_damage"}
	;tags
	{tag "stand_up"}
}
{StateWork "stand_up"
	{SyncNotifyFinish "STAND_READY"}
	{AnimName "massive_stand_up" {speed 1.1} }
}

{State "from_unmoved_3"
	;transations
	{from "mass_damage"}
	{from "pose_to_mass_damage"}
}
{StateWork "from_unmoved_3"
}

{State "from_unmoved_4"
	;transations
	{from "from_unmoved_3"}
}
{StateWork "from_unmoved_4"
}

{State "from_unmoved_5"
	;transations
	{from "from_unmoved_4"}
}
{StateWork "from_unmoved_5"
}

{State "from_stun_2"
	;transations
	{from "from_stun_3"}
}
{StateWork "from_stun_2"
}

{State "from_stun_3"
	;transations
	{from "freeze"}
	{from "stun"}
	{from "pose_to_stun"}
}
{StateWork "from_stun_3"
}

{State "from_stun_1"
	;transations
	{from "from_stun_2"}
}
{StateWork "from_stun_1"
}

{State "to_death"
	;transations
	{from "blank01"}
}
{StateWork "to_death"
}

{State "death_anim"
	;transations
	{from "to_death"}
	;tags
	{tag "death_anim"}
}
{StateWork "death_anim"
	{AnimName "death" {speed 1} {frame 2 "RAT_DEATH_SND"} }
}

{State "blank01"
	;transations
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
