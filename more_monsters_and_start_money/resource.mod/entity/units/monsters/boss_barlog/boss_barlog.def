	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "pose_to_imp_attack02_fight"}
}
{StateWork "from_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
}

;********************************************************************
; Subsets
;********************************************************************
{subset "fight"
	{enable "fight"}
	{disable "panic"}
	{disable "default"}
}

{subset "panic"
	{disable "fight"}
	{enable "panic"}
	{disable "default"}
}

{subset "default"
	{disable "fight"}
	{disable "panic"}
	{enable "default"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

