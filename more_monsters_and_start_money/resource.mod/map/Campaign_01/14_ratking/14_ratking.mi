{"helper/quests"
	{"visit_port"
		{state Active}
		{launch_condition
			{"Mission start"}
		}
		{victory_condition
			{"Arrival"
				{properties
					{zone "near_port"}
					{"Observe type" "Player unit"}
				}
			}
		}
		{victory_reaction
			{"Show Advisor"
				{properties
					{title "#11_ADVISER_NAME"}
					{message "#14_D3_Adviser_text1"}
					{picture img_msg_main_advisor}
					{Kingdom player}
				}
			}
			{"Spawn"
				{properties
					{"spawn type" "zone spawn"}
					{count 1}
					{entities caravan_eric}
					{tag super_caravan}
					{zone "caravan_appears"}
					{nationality player}
				}
			}
			{"Fog of war"
				{properties
					{type zone}
					{Zone "near_port fog_around_ship "}
					{Kingdom player}
				}
			}
			{"delay" 1}
			{"Waypoint"
				{properties
					{type tag}
					{Tag super_caravan}
					{Path caravan_path}
					{Mode pacific}
				}
			}
			{"camera.linked_trajectory"
				{properties
					{type tag}
					{Tag super_caravan}
					{Trajectory camera_rotate_180}
				}
			}
			{"Delete entity"
				{properties
					{type tag}
					{Tag port_effect}
					{Zone caravan_appears}
				}
			}
		}
		{quest_data
			{Name "#14_Quest2_name"}
			{Description "#14_Quest2_text"}
			{Quest_type Additional}
			{Kingdom player}
			{Counter_type none}
		}
	}
	{"defend_caravan"
		{state Active}
		{launch_condition
			{"Quest complete"
				{properties
					{quest visit_port}
					{state Victory}
				}
			}
		}
		{victory_condition
			{"Arrival"
				{properties
					{zone "near_castle"}
					{"Observe type" "Tagged entity"}
					{Tag super_caravan}
					{Count 1}
				}
			}
		}
		{defeat_condition
			{"Annihilation"
				{properties
					{"Entity type" "All tagged"}
					{Tag super_caravan}
				}
			}
		}
		{victory_reaction
			{"Show Advisor"
				{properties
					{title "#11_ADVISER_NAME"}
					{message "#14_D6_Adviser_text1"}
					{picture img_msg_main_advisor}
					{Kingdom player}
				}
			}
			{"Spawn"
				{properties
					{"spawn type" "zone spawn"}
					{count 1}
					{entities cheese_trap}
					{tag trap}
					{full_health}
					{zone "cheeze_trap_appears"}
					{nationality neutral}
				}
			}
			{"Delete entity"
				{properties
					{type tag}
					{Tag super_caravan}
				}
			}
			{"Update trigger"
				{properties
					{trigger ratking_appears}
					{enabled off}
				}
			}
			{"Fog of war"
				{properties
					{type zone}
					{Zone "cheese_trap_zone "}
					{Kingdom player}
				}
			}
			{"delay" 1}
			{"Waypoint"
				{properties
					{type tag}
					{Tag king}
					{Path king_path}
					{Mode pacific}
				}
			}
			{"delay" 2}
			{"Set spawn prog"
				{properties
					{type tag}
					{Tag sewers}
					{Spawn_prog "rat_01 ratman_01 greater_rat_01"}
				}
			}
			{"camera.linked_trajectory"
				{properties
					{type tag}
					{Tag trap}
					{Trajectory camera_rotate_180}
				}
			}
			{"delay" 20}
			{"Update trigger"
				{properties
					{trigger ratking_is_dead}
					{enabled on}
				}
			}
			{"Show Advisor"
				{properties
					{title "#14_Rat_king_name"}
					{message "#14_D7_Rat_king_text1"}
					{picture img_msg_ratking}
					{Kingdom player}
				}
			}
			{"delay" 135}
			{"Show Advisor"
				{properties
					{title "#14_Rat_king_name"}
					{message "#14_D4_Rat_king_text1"}
					{picture img_msg_ratking}
					{Kingdom player}
				}
			}
		}
		{defeat_reaction
			{"Show Advisor"
				{properties
					{title "#11_ADVISER_NAME"}
					{message "#14_D5_Adviser_text1"}
					{picture img_msg_main_advisor}
					{Kingdom player}
				}
			}
			{"Update trigger"
				{properties
					{trigger waiting_for_caravan}
					{enabled on}
				}
			}
		}
		{quest_data
			{Name "#14_Quest3_name"}
			{Description "#14_Quest3_text"}
			{Quest_type Additional}
			{Kingdom player}
			{Counter_type none}
		}
	}
	{"kill_ratking"
		{state Active}
		{launch_condition
			{"Mission start"}
		}
		{victory_condition
			{"Trigger complete"
				{properties
					{trigger ratking_is_dead}
				}
			}
		}
		{victory_reaction
			{"camera.linked_trajectory"
				{properties
					{type tag}
					{Tag king}
					{Trajectory camera_rotate_180}
				}
			}
			{"delay" 1}
			{"Show Advisor"
				{properties
					{title "#11_ADVISER_NAME"}
					{message "#14_Adviser_Victory"}
					{picture img_msg_main_advisor}
					{Kingdom player}
					{pause_script}
				}
			}
			{"Win mission"
				{properties
					{Kingdoms player}
				}
			}
		}
		{quest_data
			{Name "#14_Quest1_name"}
			{Description "#14_Quest1_text"}
			{Quest_type Main}
			{Kingdom player}
			{Counter_type none}
		}
	}
