{"helper/quests"
	{"destroy_mage_castle"
		{state Active}
		{launch_condition
			{"Mission start"}
		}
		{victory_condition
			{"Annihilation"
				{properties
					{"Entity type" "All tagged"}
					{Tag mage_castle}
				}
			}
		}
		{victory_reaction
			{"camera.linked_trajectory"
				{properties
					{type tag}
					{Tag mage_castle}
					{Trajectory camera_rotate_180}
				}
			}
			{"Show Advisor"
				{properties
					{title "#24_DarkMage_name"}
					{message "#24_D6_DarkMage_text1"}
					{picture img_msg_blackwizard}
					{Kingdom player}
					{pause_script}
				}
			}
			{"Spawn"
				{properties
					{"spawn type" "zone spawn"}
					{count 1}
					{entities boss_black_wizard}
					{tag super_mage}
					{zone "mage_appears"}
					{nationality enemy}
				}
			}
			{"camera.linked_trajectory"
				{properties
					{type tag}
					{Tag super_mage}
					{Trajectory "24_blackwizard_show"}
				}
			}
			{"Show Advisor"
				{properties
					{title "#24_DarkMage_name"}
					{message "#24_D8_DarkMage_text1"}
					{picture img_msg_blackwizard}
					{Kingdom player}
				}
			}
			{"Update quest"
				{properties
					{Quest kill_mage}
					{enabled on}
				}
			}
		}
		{quest_data
			{Name "#24_Quest1_name"}
			{Description "#24_Quest1_text"}
			{Quest_type Main}
			{Kingdom player}
			{Counter_type none}
		}
	}
