	{"spawn"
		{condition
			{"Mission start"}
		}
		{actions
			{"Spawn"
				{properties
					{"spawn type" "zone spawn"}
					{count 2}
					{entities fantasy_elemental_earth}
					{tag earth}
					{zone "1@temple"}
					{nationality creatures}
				}
			}
			{"Protect entity"
				{properties
					{type tag}
					{Protector_tag earth}
					{Protector_raw fantasy_elemental_earth}
					{Protect_radius 20}
					{Protected_kingdom creatures}
					{Protected_tag temple1}
					{Protected_zone "1@temple"}
				}
			}
			{"delay" 50}
			{"Set spawn prog"
				{properties
					{type tag}
					{Tag blue_wolf}
					{Spawn_prog wolves_blue}
				}
			}
			{"Set spawn prog"
				{properties
					{type tag}
					{Tag red_wolf}
					{Spawn_prog wolves_red}
				}
			}
