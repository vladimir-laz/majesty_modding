				{commodity_base {cost}
					{production_time}
					{max_count}
					{is_enabled}
					{id}
					{version "original"}
				}
			}
			{commodity "skeleton_upgrade_skeleton"
				{commodity_base {cost}
					{production_time}
					{max_count}
					{is_enabled}
					{id}
					{version "original"}
				}
			}
			{commodity "vampire_upgrade_vampire"
				{commodity_base {cost}
					{production_time}
					{max_count}
					{is_enabled}
					{id}
					{version "original"}
				}
			}
		}
		{price_list "inventions"
			{commodity "spell_grave"
				{invention_base {cost}
					{production_time}
					{max_count}
					{is_enabled}
					{id}
					{version "original"}
				}
				{invention_id}
				{building_prerequsity {buildings}
				}
				{building_count_prerequisity {building}
					{count}
				}
			}
		}
		{price_list "rest"
			{commodity "rest"
				{rest_base {cost}
					{production_time}
					{max_count}
					{is_enabled}
					{id}
					{version "original"}
				}
				{healing_time}
				{resting_time}
			}
		}
	}
}
