			}
		}
		{actions
			{"Fog of war"
				{properties
					{type zone}
					{Zone "near_player_castle for_fx_guild "}
					{Kingdom player}
				}
			}
			{"camera.linked_trajectory"
				{properties
					{type tag}
					{Tag goblin_attack}
					{Trajectory camera_rotate_180}
				}
			}
			{"delay" 2}
			{"Show Advisor"
				{properties
					{title "#11_ADVISER_NAME"}
					{message "#01_exp_01_d3_adviser_text1"}
					{picture IMG_MSG_MAIN_ADVISOR}
					{Kingdom player}
				}
			}
			{"Update quest"
				{properties
					{Quest destroy_goblins}
					{enabled on}
				}
			}
			{"Spawn"
				{properties
					{"spawn type" "fx spawn"}
					{zone "for_fx_guild"}
					{fx quest_place_fx}
					{tag guild_fx}
				}
			}
			{"css.play"
				{properties
					{css "01_exp01_goblin_guild_show"}
				}
			}
		}
	}
	{"mission_started_sound"
		{condition
			{"Mission start"}
		}
		{actions
			{"delay" 1}
			{"Play ambient"
				{properties
					{ambient "/music/ambient/amb_green_day1.mp3"}
				}
			}
			{"Play music"
				{properties
					{type fallback}
					{Music "/music/ge1.mp3 /music/ge3.mp3 /music/gm.mp3"}
					{Pause_min 45}
					{Pause_max 65}
				}
			}
		}
	}
	{## "greater_wolves_change_fraction"
		{disabled}
		{autoreset}
		{condition
			{"Arrival"
				{properties
					{zone "change_fraction"}
					{"Observe type" "Entity model"}
					{"Entity type"
						{Entity beast_greater_wolf}
					}
				}
			}
		}
		{actions
			{"if"
				{condition
					{"Tags count"
						{properties
							{Tag mongol}
							{Operation "=="}
							{Value 1}
						}
					}
				}
				{"while"
					{condition
						{"Arrival"
							{properties
								{zone "change_fraction"}
								{"Observe type" "Entity model"}
								{"Entity type"
									{Entity beast_greater_wolf}
								}
							}
						}
					}
					{"Change fraction"
						{properties
							{type raw}
							{Entities beast_greater_wolf}
							{Kingdom enemy}
							{New_kingdom player}
							{Zone change_fraction}
						}
					}
					{"delay" 1}
				}
			}
		}
	}
	{"randomizer"
		{condition
			{"Randomization"}
		}
		{actions
			{"Spawn"
				{properties
					{"spawn type" "random zone"}
					{count 1}
					{entities null_spawner}
					{tag monster_null_spawner}
					{full_health}
					{zones "c1 c2 c3"}
					{nationality enemy}
				}
			}
			{"Set spawn prog"
				{properties
					{type tag}
					{Tag monster_null_spawner}
					{Global_prog ogre_attacker}
				}
			}
			{"if"
				{condition
					{"Random"
						{properties
							{MaxRndValue 3}
