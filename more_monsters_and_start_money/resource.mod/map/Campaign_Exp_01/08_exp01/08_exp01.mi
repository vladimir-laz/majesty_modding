					{Count 1000}
					{Kingdom player}
				}
			}
		}
		{quest_data
			{Name "#08_exp01_Quest8_name"}
			{Description "#08_exp01_Quest8_text"}
			{Quest_type Additional}
			{Kingdom player}
			{Counter_type none}
		}
	}
