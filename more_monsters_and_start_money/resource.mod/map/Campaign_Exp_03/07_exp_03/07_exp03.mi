	{"main_quest"
		{state Active}
		{launch_condition
			{"Mission start"}
		}
		{victory_condition
			{"or"
				{"Annihilation"
					{properties
						{"Entity type" "All tagged"}
						{Tag enemy_castle}
					}
				}
				{"Building exist"
					{properties
						{Kingdom player}
						{Building mks_temple_arch_hero}
						{Count 4}
						{Operation "=="}
						{Completely_built 1}
					}
				}
			}
		}
		{defeat_condition
			{"Building exist"
				{properties
					{Kingdom creatures}
					{Building guild_blademaster}
					{Count 4}
					{Operation "=="}
					{Completely_built 1}
				}
			}
		}
		{victory_reaction
			{"delay" 1}
			{"if"
				{condition
					{"Annihilation"
						{properties
							{"Entity type" "All tagged"}
							{Tag enemy_castle}
						}
					}
				}
				{"delay" 1}
				{"Show Advisor"
					{properties
						{title "#11_ADVISER_NAME"}
						{message "#07_exp03_D6_Adviser_text1"}
						{picture img_msg_main_advisor}
						{Kingdom player}
						{pause_script}
					}
				}
			}
			{"if"
				{condition
					{"Building exist"
						{properties
							{Kingdom player}
							{Building mks_temple_arch_hero}
							{Count 4}
							{Operation "=="}
							{Completely_built 1}
						}
					}
				}
				{"delay" 1}
				{"Show Advisor"
					{properties
						{title "#11_ADVISER_NAME"}
						{message "#07_exp03_D5_Adviser_text1"}
						{picture img_msg_main_advisor}
						{Kingdom player}
						{pause_script}
					}
				}
			}
			{"player.regal_artefact"
				{properties
					{Mode add}
					{Kingdom player}
					{Artefact regal_scepter}
				}
			}
			{"delay" 2}
			{"Win mission"
				{properties
					{Kingdoms player}
				}
			}
		}
		{defeat_reaction
			{"delay" 1}
			{"Show Advisor"
				{properties
					{title "#11_ADVISER_NAME"}
					{message "#07_exp03_D7_Adviser_text1"}
					{picture img_msg_main_advisor}
					{Kingdom player}
					{pause_script}
				}
			}
			{"delay" 1}
			{"Lose mission"
				{properties
					{Kingdoms player}
				}
			}
		}
		{quest_data
			{Name "#07_exp03_Quest1_name"}
			{Description "#07_exp03_Quest1_text"}
			{Quest_type Main}
			{Kingdom player}
			{Counter_type none}
		}
	}
