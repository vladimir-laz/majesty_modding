{entity
	
	{"zones"
		{body {proper body sensible} {permit 	body}}
		{Collider "default"}
	}

	{actor}


;#line 10: 	(include "anim.inc")	
;#line 10: entity/units/heroes/mks_hero_minotaur/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{binary "idle_rand01"{speed 0.6}}
		{blend "pose_to_magic_attack"{pose "magic_attack" begin}}
		{binary "magic_attack"{speed 0.6}}
		{blend "pose_from_ag_idle"{pose "ag_idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_mass_damage_fly"{pose "mass_damage_fly" begin}}
		{binary "mass_damage_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
		{blend "pose_to_coward_walk"{pose "coward_walk" begin}}
		{binary "coward_walk"{speed 0.6}}
		{blend "pose_to_death"{pose "death" begin}}
		{binary "death"{speed 0.6}}
		{blend "pose_from_death"{pose "death" end}}
		{blend "pose_to_ag_walk"{pose "ag_walk" begin}}
		{binary "ag_walk"{speed 0.6}}
		{blend "pose_to_ag_idle"{pose "ag_idle" begin}}
		{binary "ag_idle"{speed 0.6}}
		{blend "pose_to_blow01"{pose "blow01" begin}}
		{binary "blow01"{speed 0.6}}
		{binary "blow02"{speed 0.6}}
	}
}
;#line 10: entity/units/heroes/mks_hero_minotaur/anim.inc END


;#line 11: 	(include "fsm.inc")		
;#line 11: entity/units/heroes/mks_hero_minotaur/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "pose_to_move_default"
	;transations
	{from "from_default"}
	{from "idle_default"}
	{from "buff_default"}
	{from "pose_to_idle_default"}
	{from "pose_to_buff_default"}
}
{StateWork "pose_to_move_default"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_default"
	;transations
	{from "pose_to_move_default"}
	;tags
	{tag "move"}
	{tag "default"}
}
{StateWork "move_default"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.1} }
}

{State "pose_to_idle_default"
	;transations
	{from "from_default"}
	{from "move_default"}
	{from "buff_default"}
	{from "pose_to_move_default"}
	{from "pose_to_buff_default"}
}
{StateWork "pose_to_idle_default"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_default"
	;transations
	{from "pose_to_idle_default"}
	;tags
	{tag "idle"}
	{tag "default"}
}
{StateWork "idle_default"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{random}
	{AnimName "idle" {speed 1} {count 2} }
	{AnimName "idle_rand01" {speed 1} }
}

{State "pose_to_buff_default"
	;transations
	{from "move_default"}
	{from "idle_default"}
	{from "from_default"}
	{from "pose_to_move_default"}
	{from "pose_to_idle_default"}
}
{StateWork "pose_to_buff_default"
	{pose}
	{AnimName "pose_to_magic_attack" {speed 0.1} }
}

{State "buff_default"
	;transations
	{from "pose_to_buff_default"}
	;tags
	{tag "buff"}
	{tag "default"}
}
{StateWork "buff_default"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "magic_attack" {speed 1.4} {frame 60 "MINOTAUR_SMALL_BLOW_SND"} {frame 68 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "freeze"
	;transations
	{from "stun"}
	{from "pose_to_stun"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
