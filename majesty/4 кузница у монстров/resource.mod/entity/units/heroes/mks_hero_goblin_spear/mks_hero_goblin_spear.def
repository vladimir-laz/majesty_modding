}

;********************************************************************
; Subsets
;********************************************************************
{subset "fight"
	{enable "fight"}
	{disable "default"}
	{disable "panic"}
}

{subset "default"
	{disable "fight"}
	{enable "default"}
	{disable "panic"}
}

{subset "panic"
	{disable "fight"}
	{disable "default"}
	{enable "panic"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

