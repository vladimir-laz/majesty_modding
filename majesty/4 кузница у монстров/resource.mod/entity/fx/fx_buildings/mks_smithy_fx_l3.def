{fx
	{#+ particle_flow "Round_Particles"
		{birth
			{limit 30}
			{speed 5}
			{## time_to_live 1}
		}
		{init
			{stage "1"}
			{"position.cylinder" 2}
			{"effect.move" local_cs
				{x 0}
				{y 5.35 0.15}
				{z 0 2}
			}
		}
		{common
			{"effect.scale" 0.06 0.01}
			{"effect.prerotate_z" 0 180}
			{"effect.color" 0xfffea100}
			{"collide.land"
				{restitution 0.5}
				{"on_collision(once)"
					{## stage}
					{delete}
				}
			}
			{"shape.sprite"
				{sprite "/texture/fx/flares/_flare0_n"}
				{orientation billboard}
				{target scene glow }
				{layer alpha}
				{blend_mode ADD}
				{center_axis}
			}
			{"test.position" sphere_outside
				{radius 7}
				{animate 1
					{## "effect.alpha"
						{to 0}
					}
					{on_end
						{delete}
					}
					{"effect.brightness"
						{to 0}
					}
				}
			}
		}
		{stages
			{"1"
				{"force.tangent" 0 0.1}
				{"force.attraction" 0 0.3
					{application axis}
				}
				{"test.age" 1
					{stage "2"}
				}
				{"effect.move"
					{x 0 1.5}
					{y 0 1.5}
					{z 0 1.5}
				}
			}
			{"2"
				{"effect.move"
					{x 0 0.5}
					{y 0 0.5}
					{z 0 0.5}
				}
				{"test.age" 1.5
					{stage "3"}
				}
			}
			{"3"
				{"force.tangent" 0 0.5}
				{animate 1
					{on_end
						{stage "1"}
					}
				}
				{"effect.move"
					{x 0 0.5}
					{y 0 0.5}
					{z 0 0.5}
				}
			}
		}
		{axis_z}
		{local_cs}
	}
	{#+ particle_flow "Round_Particles"
