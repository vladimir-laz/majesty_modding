				{"test.age" 1.5
					{stage "3"}
				}
			}
			{"3"
				{"force.tangent" 0 0.5}
				{animate 1
					{on_end
						{stage "1"}
					}
				}
				{"effect.move"
					{x 0 0.5}
					{y 0 0.5}
