{fx
	{particle_flow "Base"
		{birth
			{limit 5}
			{## batch 1}
			{speed 10}
		}
		{init}
		{common
			{"shape.sprite"
				{sprite "/texture/fx/flares/_flare0_n"}
				{target scene }
				{blend_mode ADD}
				{center_axis}
			}
			{animate 0.5
				{"effect.color"
					{to 0xff0023fe}
					{from 0xff65e0ff}
					{power 0.6}
				}
				{"effect.brightness"
					{to 1}
					{from 0}
					{peak}
				}
				{"effect.scale_xy"
					{to 0}
					{from 0.5}
				}
				{on_end
					{delete}
				}
			}
		}
		{stages}
		{offset 0 0 0}
	}
	{particle_flow "Stars"
		{birth
			{limit 10}
			{speed 10}
		}
		{init
			{"speed.cone" 0.5
				{angle 120}
			}
			{## "speed.owner"}
			{"position.sphere" 0.05}
		}
		{common
			{"shape.sprite"
				{sprite "$/flares/_flare02_n"}
				{orientation billboard}
				{target scene }
				{blend_mode ADD}
				{center_axis}
			}
			{"test.age" 0.8
				{delete}
			}
			{animate 1
				{"effect.alpha"
					{to 0}
					{from 1}
					{linear}
				}
				{"effect.scale"
					{to 0}
					{from 0.075 -0.025}
					{linear}
				}
			}
			{animate 0.5
				{"effect.color"
					{to 0xff165fff}
					{from 0xff5bbefd}
					{linear}
				}
			}
			{"effect.rotate_z" 0 180}
		}
		{axis_z}
	}
	{particle_flow "Tail"
		{birth
			{limit 10}
			{speed 10}
			{## time_to_live 1.9}
		}
		{init
			{## "speed.cone" 0.1
				{angle 90}
				{hollow}
			}
			{"position.sphere" 0.7}
		}
		{common
			{"shape.sprite"
				{sprite "$/flares/_flare07_n"}
				{orientation billboard}
				{target scene }
				{blend_mode ADD}
				{layer alpha}
				{center_axis}
			}
			{animate 0.5
				{"effect.color"
					{to 0xffd1004a}
					{from 0xff000000}
					{peak}
				}
				{"effect.scale_xy"
					{to 0.3}
					{from 0.5}
				}
			}
			{"test.age" 1
				{delete}
			}
			{"effect.prerotate_z" 0 180}
			{## "effect.acc_z" 1.5}
			{"effect.acc" global_cs
				{x 0}
				{y 0}
				{z 5 1}
			}
		}
		{axis_z}
		{local_cs}
	}
}
