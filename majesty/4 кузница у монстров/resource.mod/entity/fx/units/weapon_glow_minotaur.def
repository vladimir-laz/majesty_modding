					{x 0}
					{y 2}
					{z 1}
				}
			}
			{"effect.prerotate_z" 0 180}
			{split
				{branch
					{"shape.sprite"
						{sprite "$/flares/ightning_particle2_n"}
						{orientation billboard}
						{target scene glow }
						{layer alpha}
						{blend_mode ADD}
						{center_axis}
					}
				}
				{branch
					{"shape.sprite"
						{sprite "$/flares/ightning_particle2_n"}
						{orientation billboard}
						{target scene }
						{layer alpha}
						{blend_mode ADD}
						{center_axis}
					}
				}
			}
		}
		{stages}
		{## axis_z}
		{local_cs}
	}
	{light
		{animator
			{timer
				{mode loop }
				{duration 4}
			}
			{scale 4
