					{to 0.25}
					{from 0.3}
					{linear}
				}
				{"effect.color"
					{to 0xfff60000}
					{from 0xff000000}
					{peak}
				}
				{on_end
					{delete}
				}
				{"effect.rotate_z"
					{to 45 15}
				}
			}
			{## "effect.acc_z" 3.5}
			{"effect.move" local_cs
				{x 0}
				{y 2}
				{z -1}
			}
			{"test.age" 0
