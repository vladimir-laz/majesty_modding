{fx
	{particle_flow "Tail"
		{birth
			{limit 15}
			{speed 15}
			{## time_to_live 1.9}
		}
		{init
			{"position.sphere" 0.5}
			{"speed.cone" 0.1
				{angle 90}
				{hollow}
			}
		}
		{common
			{"shape.sprite"
				{sprite "$/flares/_flare07_n"}
				{orientation billboard}
				{target scene }
				{blend_mode ADD}
				{layer alpha}
				{center_axis}
			}
			{animate 1
				{"effect.color"
					{to 0xff86058e}
					{from 0xff000000}
					{peak}
				}
				{"effect.scale_xy"
					{to 0.15}
					{from 0.6}
				}
			}
			{"test.age" 1
				{delete}
			}
			{"effect.prerotate_z" 0 180}
		}
		{axis_z}
		{## local_cs}
	}
	{particle_flow "lighting"
		{birth
			{limit 6}
			{speed 6}
			{## time_to_live 1}
		}
		{init
			{"position.sphere" 0.7}
			{"speed.cone" 0.1
				{angle 90}
				{hollow}
			}
		}
		{common
			{"shape.sprite"
				{sprite "$/flares/ightning_particle2_n"}
				{orientation billboard}
				{target scene glow }
				{layer alpha}
				{blend_mode ADD}
				{center_axis}
			}
			{animate 1
				{"effect.color"
					{to 0xfff60000}
					{from 0xff000000}
					{peak}
				}
				{"effect.scale"
					{to 0.275 0.075}
					{from 0.325 0.075}
					{linear}
				}
			}
			{"test.age" 1
				{delete}
			}
			{"effect.prerotate_z" 0 180}
		}
		{axis_z}
		{## local_cs}
	}
}
