{fx
	{particle_flow
		{birth
			{limit 5}
			{speed 10}
			{## time_to_live 2}
		}
		{init
			{"position.sphere" 0.5
				{hollow}
			}
		}
		{common
			{## "test.age" 0.25
				{delete}
			}
			{animate 0.2
				{"effect.color"
					{to 0xff0011fe}
					{from 0xffa4e4fe}
				}
				{on_end
					{animate 0.3
						{"effect.color"
							{to 0xff000000}
						}
						{on_end
							{delete}
						}
					}
				}
			}
			{"effect.scale_xy" 0.275 -0.05}
			{"effect.prerotate_z" 0 -180}
			{split
				{branch
					{"shape.sprite"
						{sprite "$/flares/lightningcrack_n"}
						{orientation billboard}
						{target scene }
						{blend_mode ADD}
						{center_axis}
					}
				}
				{branch
					{"shape.sprite"
						{sprite "$/flares/lightningcrack_n"}
						{orientation billboard}
						{target scene glow }
						{blend_mode ADD}
						{center_axis}
					}
				}
			}
			{"effect.acc_z" 0.5 0.2}
		}
		{axis_z}
		{local_cs}
	}
}
