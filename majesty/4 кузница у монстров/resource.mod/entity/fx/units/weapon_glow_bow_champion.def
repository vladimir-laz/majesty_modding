{fx
	{particle_flow "stars"
		{birth
			{limit 9}
			{speed 9}
		}
		{init
			{## "speed.owner"}
			{"position.sphere" 1.4
				{hollow}
			}
			{"effect.move" local_cs
				{x 0}
				{y 0}
				{z 0}
			}
		}
		{common
			{"shape.sprite"
				{sprite "$/flares/_flare02_n"}
				{orientation billboard}
				{target scene glow }
				{blend_mode ADD}
				{center_axis}
			}
			{animate 1
				{"effect.alpha"
					{to 0}
					{from 1}
					{linear}
				}
				{"effect.scale"
					{to 0}
					{from 0.075 0.025}
					{linear}
				}
				{on_end
					{delete}
				}
				{"effect.color"
					{to 0xff2f0f00}
					{from 0xfffbfbfb}
					{linear}
				}
			}
			{"effect.rotate_z" 0 180}
			{## "force.attraction" -1
				{application origin}
			}
		}
		{axis_z}
		{local_cs}
	}
