{fx
	{particle_flow "smoke"
		{birth
			{limit 32}
			{speed 16}
			{## time_to_live 1.9}
		}
		{init
			{"position.sphere" 1}
			{"effect.move" local_cs
				{x 0}
				{y 0}
				{z 0.1}
			}
		}
		{common
			{"shape.sprite"
				{sprite "$/flares/_flare07"}
				{orientation billboard}
				{target scene }
				{blend_mode BLEND}
				{layer alpha}
				{center_axis}
			}
			{animate 2
				{"effect.color"
					{to 0xff000000}
					{from 0xff000000}
					{peak}
				}
				{"effect.scale_xy"
					{to 0.225}
					{from 0.425}
				}
				{"effect.alpha"
					{to 0.5}
					{from 0}
					{peak}
				}
				{on_end
					{delete}
				}
			}
			{"effect.prerotate_z" 0 180}
			{## "effect.acc_z" 0.5}
			{"effect.move" global_cs
				{x 0}
				{y 0}
				{z 0.4}
			}
		}
		{axis_z}
		{local_cs}
	}
	{particle_flow "Star"
		{birth
			{limit 15}
			{speed 15}
			{## time_to_live 1.9}
		}
		{init
			{"position.sphere" 1.1}
			{"effect.move" local_cs
				{x 0}
				{y 0}
				{z 0.4}
			}
		}
		{common
			{"shape.sprite"
				{sprite "$/flares/_flare05_n"}
				{orientation billboard}
				{target scene glow }
				{blend_mode ADD}
				{layer alpha}
				{center_axis}
			}
			{animate 1
				{"effect.scale_xy"
					{to 0}
					{from 0.125 -0.025}
				}
				{## "effect.rotate_z"
					{to 0 -180}
				}
				{"effect.color"
					{to 0x18C6FFC600}
					{from 0xff000000}
					{peak}
				}
				{on_end
					{delete}
				}
			}
			{"effect.prerotate_z" 0 180}
			{## "effect.color" 0xffdc4aff}
		}
		{stages}
	}
}
