;#line 10: 	(include "anim.inc")	
;#line 10: /entity/units/monsters/beast_bearman_polar/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_to_blow01"{pose "blow01" begin}}
		{binary "blow01"{speed 0.6}}
		{binary "blow02"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.4}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{blend "pose_to_cast01"{pose "cast01" begin}}
		{binary "cast01"{speed 0.6}}
		{binary "death01"{speed 0.6}}
		{blend "pose_from_death01"{pose "death01" end}}
		{blend "pose_to_ag_walk"{pose "ag_walk" begin}}
		{binary "ag_walk"{speed 0.6}}
		{binary "idle_rand01"{speed 0.6}}
		{binary "idle_rand02"{speed 0.6}}
		{blend "pose_from_idle"{pose "idle" end}}
		{blend "pose_to_stun"{pose "stun" begin}}
		{binary "stun"{speed 0.6}}
		{blend "pose_to_mass_damage_fly"{pose "mass_damage_fly" begin}}
		{binary "mass_damage_fly"{speed 0.6}}
		{binary "massive_stand_up"{speed 0.6}}
	}
}
;#line 10: /entity/units/monsters/beast_bearman_polar/anim.inc END
{"FogVisor"
	{radius 4}
}

;#line 11: 	(include "fsm.inc")		
;#line 11: /entity/units/monsters/beast_bearman_polar/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "pose_to_attack_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_attack_fight"
	{pose}
	{AnimName "pose_to_blow01" {speed 0.4} }
}

{State "attack_fight"
	;transations
	{from "pose_to_attack_fight"}
	;tags
	{tag "attack"}
	{tag "fight"}
}
{StateWork "attack_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{random}
	{AnimName "blow01" {speed 1} {frame 28 "BEARMAN_BLOW01_SND"} {frame 30 "IMP_SWISH_SND"} {frame 32 "ATTACK"} {frame -1 "ATTACK"} }
	{AnimName "blow02" {speed 1} {frame 36 "BEARMAN_BLOW02_SND"} {frame 47 "IMP_SWISH_SND"} {frame 52 "ATTACK"} {frame 61 "IMP_SWISH_SND"} {frame -1 "ATTACK"} }
}

{State "pose_to_move_fight"
	;transations
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_move_fight"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_fight"
	;transations
	{from "pose_to_move_fight"}
	;tags
	{tag "move"}
	{tag "fight"}
}
{StateWork "move_fight"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.2} }
}

{State "pose_to_idle_fight"
