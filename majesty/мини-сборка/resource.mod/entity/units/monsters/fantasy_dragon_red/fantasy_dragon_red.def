;#line 9: 	(include "anim.inc")		
;#line 9: /entity/units/monsters/fantasy_dragon_red/anim.inc BEGIN
{Skeleton
	{animation
		{blend "pose_to_death"{pose "death" begin}}
		{binary "death"{speed 0.6}}
		{blend "pose_to_idle"{pose "idle" begin}}
		{binary "idle"{speed 0.6}}
		{blend "pose_to_ag_walk"{pose "ag_walk" begin}}
		{binary "ag_walk"{speed 0.6}}
		{blend "pose_to_walk"{pose "walk" begin}}
		{binary "walk"{speed 0.6}}
		{binary "idle_rand01"{speed 0.6}}
		{blend "pose_to_magic_attack01"{pose "magic_attack01" begin}}
		{binary "magic_attack01"{speed 0.6}}
		{blend "pose_to_ag_idle"{pose "ag_idle" begin}}
		{binary "ag_idle"{speed 0.6}}
		{blend "pose_to_magic_attack02"{pose "magic_attack02" begin}}
		{binary "magic_attack02"{speed 0.6}}
	}
}
;#line 9: /entity/units/monsters/fantasy_dragon_red/anim.inc END

{"FogVisor"
	{radius 4}
}
;#line 10: 	(include "fsm.inc")			
;#line 10: /entity/units/monsters/fantasy_dragon_red/fsm.inc BEGIN
{"FSM.AnimationsFSM"

;********************************************************************
; Requests
;********************************************************************
	{AnimRequest "idle" {System "PRE_IDLE"}}

	{AnimRequest "move" {System "PRE_MOVE"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_LEFT"}}

	{AnimRequest "rotate" {System "PRE_ROTATE_RIGHT"}}

	{AnimRequest "attack" {System "PRE_MELEE_ATTACK"}}

	{AnimRequest "death" {System "PRE_DEATH"}}

;********************************************************************
; States
;********************************************************************
{State "to_death"
	;transations
	{from "blank01"}
}
{StateWork "to_death"
	{SyncNotifyStart "DEATH"}
	{pose}
	{AnimName "pose_to_death" {speed 0.25} }
}

{State "death"
	;transations
	{from "to_death"}
	;tags
	{tag "death"}
}
{StateWork "death"
	{SyncNotifyFinish "DEATH"}
	{AnimName "death" {speed 1} {frame 1 "DRAGON_DEATH_SND"} {frame 41 "BODYFALL_HEAVY_SND"} {frame -1 "DEATH"} }
}

{State "blank01"
	;transations
	{from "pose_to_idle_panic"}
	{from "idle_panic"}
	{from "pose_to_move_panic"}
	{from "move_panic"}
	{from "pose_to_move_default"}
	{from "move_default"}
	{from "pose_to_idle_default"}
	{from "idle_default"}
	{from "pose_to_attack_fight"}
	{from "attack_fight"}
	{from "pose_to_move_fight"}
	{from "move_fight"}
	{from "pose_to_idle_fight"}
	{from "idle_fight"}
	{from "pose_to_imp_attack01_fight"}
	{from "imp_attack01_fight"}
	{from "from_default"}
	{from "from_panic"}
	{from "from_fight"}
}
{StateWork "blank01"
}

{State "pose_to_idle_panic"
	;transations
	{from "from_panic"}
	{from "move_panic"}
	{from "pose_to_move_panic"}
}
{StateWork "pose_to_idle_panic"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_panic"
	;transations
	{from "pose_to_idle_panic"}
	;tags
	{tag "idle"}
	{tag "panic"}
}
{StateWork "idle_panic"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "idle" {speed 0.9} {frame 26 "DRAGON_WING_SND"} }
}

{State "pose_to_move_panic"
	;transations
	{from "from_panic"}
	{from "idle_panic"}
	{from "pose_to_idle_panic"}
}
{StateWork "pose_to_move_panic"
	{pose}
	{AnimName "pose_to_ag_walk" {speed 0.25} }
}

{State "move_panic"
	;transations
	{from "pose_to_move_panic"}
	;tags
	{tag "move"}
	{tag "panic"}
}
{StateWork "move_panic"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_walk" {speed 1.2} {frame 19 "DRAGON_WING_SND"} }
}

{State "pose_to_move_default"
	;transations
	{from "from_default"}
	{from "idle_default"}
	{from "pose_to_idle_default"}
}
{StateWork "pose_to_move_default"
	{pose}
	{AnimName "pose_to_walk" {speed 0.25} }
}

{State "move_default"
	;transations
	{from "pose_to_move_default"}
	;tags
	{tag "move"}
	{tag "default"}
}
{StateWork "move_default"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "walk" {speed 1.1} {frame 17 "DRAGON_WING_SND"} {frame 39 "DRAGON_WING_SND"} {frame 48 "DRAGON_WING_IDLE_SND"} {frame 116 "DRAGON_WING_SND"} {frame 120 "DRAGON_WING_IDLE_SND"} }
}

{State "pose_to_idle_default"
	;transations
	{from "move_default"}
	{from "from_default"}
	{from "pose_to_move_default"}
}
{StateWork "pose_to_idle_default"
	{pose}
	{AnimName "pose_to_idle" {speed 0.25} }
}

{State "idle_default"
	;transations
	{from "pose_to_idle_default"}
	;tags
	{tag "idle"}
	{tag "default"}
}
{StateWork "idle_default"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{random}
	{AnimName "idle" {speed 1} {count 3} {frame 26 "DRAGON_WING_SND"} }
	{AnimName "idle_rand01" {speed 1} {frame 19 "DRAGON_WING_SND"} {frame 35 "DRAGON_WING_SND"} {frame 40 "DRAGON_SOUND_SND"} {frame 89 "DRAGON_WING_SND"} }
}

{State "pose_to_attack_fight"
	;transations
	{from "idle_fight"}
	{from "move_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_attack_fight"
	{pose}
	{AnimName "pose_to_magic_attack01" {speed 0.4} }
}

{State "attack_fight"
	;transations
	{from "pose_to_attack_fight"}
	;tags
	{tag "attack"}
	{tag "fight"}
}
{StateWork "attack_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "magic_attack01" {speed 1} {frame 27 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "pose_to_move_fight"
	;transations
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_move_fight"
	{pose}
	{AnimName "pose_to_ag_walk" {speed 0.25} }
}

{State "move_fight"
	;transations
	{from "pose_to_move_fight"}
	;tags
	{tag "move"}
	{tag "fight"}
}
{StateWork "move_fight"
	{SyncNotifyStart "MOVE_RESUME"}
	{SyncNotifyFinish "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_walk" {speed 1.2} {frame 19 "DRAGON_WING_SND"} }
}

{State "pose_to_idle_fight"
	;transations
	{from "move_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "imp_attack01_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "pose_to_idle_fight"
	{pose}
	{AnimName "pose_to_ag_idle" {speed 0.25} }
}

{State "idle_fight"
	;transations
	{from "pose_to_idle_fight"}
	;tags
	{tag "idle"}
	{tag "fight"}
}
{StateWork "idle_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
	{looped}
	{AnimName "ag_idle" {speed 1} {frame 6 "DRAGON_WING_SND"} }
}

{State "pose_to_imp_attack01_fight"
	;transations
	{from "move_fight"}
	{from "idle_fight"}
	{from "attack_fight"}
	{from "from_fight"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
}
{StateWork "pose_to_imp_attack01_fight"
	{pose}
	{AnimName "pose_to_magic_attack02" {speed 0.4} }
}

{State "imp_attack01_fight"
	;transations
	{from "pose_to_imp_attack01_fight"}
	;tags
	{tag "imp_attack01"}
	{tag "fight"}
}
{StateWork "imp_attack01_fight"
	{SyncNotifyStart "ATTACK"}
	{SyncNotifyFinish "ATTACK"}
	{AnimName "magic_attack02" {speed 1} {frame 25 "ATTACK"} {frame -1 "ATTACK"} }
}

{State "from_default"
	;transations
	{from "move_default"}
	{from "idle_default"}
	{from "from_panic"}
	{from "from_fight"}
	{from "death"}
	{from "pose_to_move_default"}
	{from "pose_to_idle_default"}
}
{StateWork "from_default"
	{SyncNotifyStart "MOVE_PAUSE"}
}

{State "from_panic"
	;transations
	{from "idle_panic"}
	{from "move_panic"}
	{from "from_default"}
	{from "from_fight"}
	{from "death"}
	{from "pose_to_idle_panic"}
	{from "pose_to_move_panic"}
}
{StateWork "from_panic"
	{SyncNotifyStart "MOVE_PAUSE"}
}

{State "from_fight"
	;transations
	{from "from_default"}
	{from "from_panic"}
	{from "idle_fight"}
	{from "move_fight"}
	{from "attack_fight"}
	{from "imp_attack01_fight"}
	{from "death"}
	{from "pose_to_attack_fight"}
	{from "pose_to_move_fight"}
	{from "pose_to_idle_fight"}
	{from "pose_to_imp_attack01_fight"}
}
{StateWork "from_fight"
	{SyncNotifyStart "MOVE_PAUSE"}
}

;********************************************************************
; Subsets
;********************************************************************
{subset "panic"
	{enable "panic"}
	{disable "default"}
	{disable "fight"}
}

{subset "default"
	{disable "panic"}
	{enable "default"}
	{disable "fight"}
}

{subset "fight"
	{disable "panic"}
	{disable "default"}
	{enable "fight"}
}

;********************************************************************
; Start state \ subset
;********************************************************************
	{Start "idle_default"}

	{WorkSubset "default"}

}

