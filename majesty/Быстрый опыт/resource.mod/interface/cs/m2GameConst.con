m2PursueTask_LimitTime  		10.0	; предел преследования цели в секундах

; Настройки сети
m2TimeBetweenQuantCommands		0.0	; Для сервера - Время между командами кванта, то есть насколько быстро действие, сделанное игроком передасться на сервер. Теоретически, это можно сравнить с ФПС. По сути чем меньше это число, тем лучше. В оригинале стояло "0.07" - методом тестов я понял, что это время, с которым моё действие (например постройка башни) передасться на сервер 
m2TimeBetweenQuantReports		0.0	; Для всех - Время между квантовыми отчетами, то есть задержка (в оригинале стояло "0.05). Я поставил "0.0", чтобы убрать вообще задержку. Она влияет на замедление - то есть чем больше число, тем больше будет замедление (юниты медлее ходить, здания строится и тд и тп)
m2QuantSmoothFactor			0.015	; Для всех. Методом тыка и изменений я проводил исследования. Вроде как это герцовка. То бишь то, насколько быстро действия, проводимые игроками я увижу это у себя на экране - например исцелить заклинанием героя. В оригинале стояло "0.015", и я не трогал это число, ибо есть поставить "0.0" то почему-то всё будет очень медленно если свернуть игру и развернуть обратно. В общем херня полная с этой настройкай, лучше сюда свой нос не сувать.

m2PartyGatherCost				500.0	; стоимость сбора партии в таверне
m2PartyGatherRadius			15.0	; расстояние от таверны, на котором производится сбор партии

m2ResurrectCostCoefficient_1 		1	; коэффициент формулы воскрешения №1
m2ResurrectCostCoefficient_2		0.5	; коэффициент формулы воскрешения №2; стоимость_воскрешения=начальная_стоимость*коэффициент_1 * (1 + коэффициент_2*(уровень-1))

m2UpgradeCostCoefficient_1 		1	; коэффициент формулы апгрейда №1
m2UpgradeCostCoefficient_2		0.2	; коэффициент формулы апгрейда №2; стоимость_апгрейда=начальная_стоимость*коэффициент_1 * (1 + коэффициент_2*(уровень-1))


m2LordCostCoefficient_1 		1	; ТА-ДАМ! коэффициент формулы покупки лорда №1
m2LordCostCoefficient_2			0.5	; коэффициент формулы покупки лорда №2; стоимость_покупки_лорда=начальная_стоимость*коэффициент_1 * (1 + коэффициент_2*(уровень-1))


