m2SleepTask_SleepTime 			220	; время, которое проспит огр (в секундах)

m2UnitUpgradeFx					"unit_upgrade_fx"	; спецэффект для прокачки юнитов
m2UnitUpgradeDelay			0.5	; задержка перед апгрейдом юнита, что бы спецэффект мог набрать силу и закрыть его
